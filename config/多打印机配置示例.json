    {
      "name": "佳博GP-58",
      "types": ["receipt", "escpos"],
      "ip": "192.168.1.100",
      "port": 9100,
      "说明": "热敏小票打印机 - 处理收据和订单"
    }
  ],
  "使用说明": {
    "types支持的值": [
      "label - ZPL标签打印",
      "pdf - PDF文档打印",
      "receipt - ESC/POS小票打印",
      "escpos - ESC/POS打印（同receipt）",
      "* - 通配符，处理所有类型"
    ],
    "配置方式": [
      "name - 打印机名称（支持模糊搜索）",
      "ip - 网络打印机IP地址",
      "port - 网络端口（默认9100）",
      "device - Linux设备路径"
    ],
    "default": "设置为true的打印机将作为默认打印机"
  }
}

